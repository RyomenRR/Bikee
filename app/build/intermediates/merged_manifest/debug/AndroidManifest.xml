<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.ryomen.bikee"
    android:versionCode="1"
    android:versionName="1.2" >

    <uses-sdk
        android:minSdkVersion="21"
        android:targetSdkVersion="33" />

    <!-- 📡 Bluetooth & Location permissions -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- 📱 Android 12+ Bluetooth permissions -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        android:required="false" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:required="false" />

    <!-- 🎤 Voice & Internet -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <package android:name="com.itsaky.androidide" />
    </queries>

    <uses-permission android:name="com.itsaky.androidide.permission.BIND_LOG_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <permission
        android:name="com.ryomen.bikee.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.ryomen.bikee.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Bikee" >

        <!-- 🏍️ Main Activity (Handles launcher, shortcut & assistant trigger) -->
        <activity
            android:name="com.ryomen.bikee.MainActivity"
            android:exported="true"
            android:launchMode="singleTop" >

            <!-- 📱 Launcher icon -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- 🔗 Shortcut or Assistant trigger (bikee://start_bike) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="start_bike"
                    android:scheme="bikee" />
            </intent-filter>
        </activity>

        <receiver
            android:name="com.ryomen.bikee.StartBikeReceiver"
            android:exported="true" >
            <intent-filter>
                <action android:name="com.ryomen.bikee.START_BIKE" />
            </intent-filter>
        </receiver>
        <!-- 🛠 Voice Command Editor -->
        <activity
            android:name="com.ryomen.bikee.CommandEditActivity"
            android:exported="true" />

        <!-- 🧠 Invisible Shortcut Handler -->
        <activity
            android:name="com.ryomen.bikee.StartBikeActivity"
            android:exported="true"
            android:theme="@style/Theme.Bikee.ShortcutNoUI" />

        <!-- 🚀 Shortcut XML config (for Android launcher) -->
        <meta-data
            android:name="android.app.shortcuts"
            android:resource="@xml/shortcuts" />

        <provider
            android:name="com.itsaky.androidide.logsender.utils.LogSenderInstaller"
            android:authorities="com.ryomen.bikee.logsender-installer"
            android:enabled="@bool/logsender_enabled"
            android:exported="false" />

        <service
            android:name="com.itsaky.androidide.logsender.LogSenderService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.ryomen.bikee.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>

</manifest>